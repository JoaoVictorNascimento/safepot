{
  "name": "safepot",
  "version": "0.1.0",
  "description": "A lightweight and performant state management library built on modern React principles, with optional enterprise-grade architecture",
  "license": "MIT",
  "author": "João Victor Nascimento",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoaoVictorNascimento/safepot.git"
  },
  "homepage": "https://github.com/JoaoVictorNascimento/safepot#readme",
  "bugs": {
    "url": "https://github.com/JoaoVictorNascimento/safepot/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "vanilla-test": "tsx examples/demo/src/tests/vanilla-test.ts"
  },
  "keywords": [
    "state-management",
    "react",
    "zustand",
    "store",
    "state",
    "frontend",
    "typescript"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
